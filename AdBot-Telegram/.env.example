# ─────────────────────────────────────────────────────────────
# .env — AdBot-Telegram configuration
# Copy this file: cp .env.example .env
# Then fill in your values below
# ─────────────────────────────────────────────────────────────

# REQUIRED — Get from https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# REQUIRED — Get from https://aistudio.google.com/app/apikey (free)
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL — Get from https://huggingface.co/settings/tokens (free)
# Only needed for backup image generation. Pollinations.ai works without any key.
HF_API_KEY=

# OPTIONAL — Canva Affiliate Tag for passive income
# Sign up free: https://www.canva.com/affiliates/
# Earn 25-80% commission on every Canva signup via your link
CANVA_AFFILIATE_TAG=
